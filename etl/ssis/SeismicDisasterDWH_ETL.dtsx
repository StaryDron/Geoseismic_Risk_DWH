<?xml version="1.0"?>
<DTS:Executable xmlns:DTS="www.microsoft.com/SqlServer/Dts"
  DTS:refId="Package"
  DTS:CreationDate="6/9/2026 3:00:00 AM"
  DTS:DTSID="{1A2B3C4D-E5F6-7A8B-9C0D-E1F2A3B4C5D6}"
  DTS:ExecutableType="MSDTS100.Package.1"
  DTS:LocaleID="1033"
  DTS:ObjectName="SeismicDisasterDWH_ETL"
  DTS:PackageType="5"
  DTS:VersionBuild="1"
  DTS:VersionGUID="{1A2B3C4D-E5F6-7A8B-9C0D-E1F2A3B4C5D7}">

  <!-- ======================================================================
       CONNECTION MANAGERS
       Update ConnectionString values to match your SQL Server instance.
       ====================================================================== -->
  <DTS:ConnectionManagers>

    <DTS:ConnectionManager
      DTS:refId="Package.ConnectionManagers[CM_DWH]"
      DTS:CreationName="OLEDB"
      DTS:DTSID="{2A3B4C5D-E6F7-8A9B-0C1D-E2F3A4B5C6D7}"
      DTS:ObjectName="CM_DWH">
      <DTS:ObjectData>
        <ConnectionManager
          ConnectionString="Data Source=localhost;Initial Catalog=SeismicDisasterDWH;Provider=SQLNCLI11;Integrated Security=SSPI;Auto Translate=False;" />
      </DTS:ObjectData>
    </DTS:ConnectionManager>

    <DTS:ConnectionManager
      DTS:refId="Package.ConnectionManagers[CM_STG]"
      DTS:CreationName="OLEDB"
      DTS:DTSID="{3A4B5C6D-E7F8-9A0B-1C2D-E3F4A5B6C7D8}"
      DTS:ObjectName="CM_STG">
      <DTS:ObjectData>
        <ConnectionManager
          ConnectionString="Data Source=localhost;Initial Catalog=SeismicDisasterSTG;Provider=SQLNCLI11;Integrated Security=SSPI;Auto Translate=False;" />
      </DTS:ObjectData>
    </DTS:ConnectionManager>

  </DTS:ConnectionManagers>

  <!-- ======================================================================
       PACKAGE PARAMETERS
       ====================================================================== -->
  <DTS:PackageParameters>
    <DTS:PackageParameter
      DTS:DataType="8"
      DTS:DTSID="{4A5B6C7D-E8F9-0A1B-2C3D-E4F5A6B7C8D9}"
      DTS:Name="PythonScriptPath"
      DTS:ParameterRequired="true">
      <DTS:Property DTS:Name="ParameterValue">C:\Users\Mateu\Github\DWH\Geoseismic_Risk_DWH\etl\python</DTS:Property>
    </DTS:PackageParameter>
    <DTS:PackageParameter
      DTS:DataType="8"
      DTS:DTSID="{5A6B7C8D-E9F0-1A2B-3C4D-E5F6A7B8C9D0}"
      DTS:Name="PythonExe"
      DTS:ParameterRequired="true">
      <DTS:Property DTS:Name="ParameterValue">python</DTS:Property>
    </DTS:PackageParameter>
  </DTS:PackageParameters>

  <!-- ======================================================================
       EXECUTABLES (tasks in execution order)
       ====================================================================== -->
  <DTS:Executables>

    <!-- ------------------------------------------------------------------ -->
    <!-- SEQUENCE: Extract Layer                                              -->
    <!-- ------------------------------------------------------------------ -->
    <DTS:Executable
      DTS:refId="Package\SEQ_Extract"
      DTS:CreationName="STOCK:SEQUENCE"
      DTS:DTSID="{6A7B8C9D-E0F1-2A3B-4C5D-E6F7A8B9C0D1}"
      DTS:ObjectName="SEQ_Extract">

      <DTS:Executables>

        <!-- Extract USGS via Python -->
        <DTS:Executable
          DTS:refId="Package\SEQ_Extract\EPT_ExtractUSGS"
          DTS:CreationName="Microsoft.SqlServer.Dts.Tasks.ExecuteProcess.ExecuteProcessTask, Microsoft.SqlServer.ExecProcTask, Version=16.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91"
          DTS:DTSID="{7A8B9C0D-E1F2-3A4B-5C6D-E7F8A9B0C1D2}"
          DTS:ObjectName="EPT_ExtractUSGS"
          DTS:Description="Download seismic events from USGS REST API (incremental)">
          <DTS:ObjectData>
            <ExecuteProcessData>
              <Executable>$Package::PythonExe</Executable>
              <Arguments>extract_usgs.py</Arguments>
              <WorkingDirectory>$Package::PythonScriptPath</WorkingDirectory>
              <StandardInputVariable></StandardInputVariable>
              <StandardOutputVariable></StandardOutputVariable>
              <StandardErrorVariable></StandardErrorVariable>
              <FailTaskIfReturnCodeIsNotSuccessValue>true</FailTaskIfReturnCodeIsNotSuccessValue>
              <SuccessValue>0</SuccessValue>
              <TimeOut>7200</TimeOut>
              <WindowStyle>3</WindowStyle>
            </ExecuteProcessData>
          </DTS:ObjectData>
        </DTS:Executable>

        <!-- Extract EMDAT via Python (on_fail = continue – file may not exist yet) -->
        <DTS:Executable
          DTS:refId="Package\SEQ_Extract\EPT_ExtractEMDAT"
          DTS:CreationName="Microsoft.SqlServer.Dts.Tasks.ExecuteProcess.ExecuteProcessTask, Microsoft.SqlServer.ExecProcTask, Version=16.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91"
          DTS:DTSID="{8A9B0C1D-E2F3-4A5B-6C7D-E8F9A0B1C2D3}"
          DTS:ObjectName="EPT_ExtractEMDAT"
          DTS:Description="Load EMDAT CSV export (Earthquake filter) to staging">
          <DTS:ObjectData>
            <ExecuteProcessData>
              <Executable>$Package::PythonExe</Executable>
              <Arguments>extract_emdat.py</Arguments>
              <WorkingDirectory>$Package::PythonScriptPath</WorkingDirectory>
              <StandardInputVariable></StandardInputVariable>
              <StandardOutputVariable></StandardOutputVariable>
              <StandardErrorVariable></StandardErrorVariable>
              <FailTaskIfReturnCodeIsNotSuccessValue>false</FailTaskIfReturnCodeIsNotSuccessValue>
              <SuccessValue>0</SuccessValue>
              <TimeOut>1800</TimeOut>
              <WindowStyle>3</WindowStyle>
            </ExecuteProcessData>
          </DTS:ObjectData>
        </DTS:Executable>

      </DTS:Executables>

      <!-- Run EPT_ExtractUSGS first, then EPT_ExtractEMDAT -->
      <DTS:PrecedenceConstraints>
        <DTS:PrecedenceConstraint
          DTS:refId="Package\SEQ_Extract.PrecedenceConstraints[Constraint]"
          DTS:DTSID="{9A0B1C2D-E3F4-5A6B-7C8D-E9F0A1B2C3D4}"
          DTS:EvalOp="1"
          DTS:LogicalAnd="True"
          DTS:From="Package\SEQ_Extract\EPT_ExtractUSGS"
          DTS:To="Package\SEQ_Extract\EPT_ExtractEMDAT" />
      </DTS:PrecedenceConstraints>

    </DTS:Executable>

    <!-- ------------------------------------------------------------------ -->
    <!-- SEQUENCE: Transform & Load                                           -->
    <!-- ------------------------------------------------------------------ -->
    <DTS:Executable
      DTS:refId="Package\SEQ_Transform"
      DTS:CreationName="STOCK:SEQUENCE"
      DTS:DTSID="{0A1B2C3D-E4F5-6A7B-8C9D-E0F1A2B3C4D5}"
      DTS:ObjectName="SEQ_Transform"
      DTS:Description="Load dimensions and facts from staging to DWH">

      <DTS:Executables>

        <!-- Step 3: Load DimGeography (SCD2) -->
        <DTS:Executable
          DTS:refId="Package\SEQ_Transform\SQL_LoadDimGeography"
          DTS:CreationName="Microsoft.SqlServer.Dts.Tasks.ExecuteSQLTask.ExecuteSQLTask, Microsoft.SqlServer.SQLTask, Version=16.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91"
          DTS:DTSID="{1B2C3D4E-F5A6-7B8C-9D0E-F1A2B3C4D5E6}"
          DTS:ObjectName="SQL_LoadDimGeography">
          <DTS:ObjectData>
            <SqlTaskData
              DTS:Connection="Package.ConnectionManagers[CM_DWH]"
              DTS:SqlStatementSource="EXEC dbo.usp_Load_DimGeography;"
              DTS:ResultType="1"
              DTS:TimeOut="300" />
          </DTS:ObjectData>
        </DTS:Executable>

        <!-- Step 4: Load FactSeismic -->
        <DTS:Executable
          DTS:refId="Package\SEQ_Transform\SQL_LoadFactSeismic"
          DTS:CreationName="Microsoft.SqlServer.Dts.Tasks.ExecuteSQLTask.ExecuteSQLTask, Microsoft.SqlServer.SQLTask, Version=16.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91"
          DTS:DTSID="{2C3D4E5F-A6B7-8C9D-0E1F-A2B3C4D5E6F7}"
          DTS:ObjectName="SQL_LoadFactSeismic">
          <DTS:ObjectData>
            <SqlTaskData
              DTS:Connection="Package.ConnectionManagers[CM_DWH]"
              DTS:SqlStatementSource="EXEC dbo.usp_Load_FactSeismic;"
              DTS:ResultType="1"
              DTS:TimeOut="1800" />
          </DTS:ObjectData>
        </DTS:Executable>

        <!-- Step 5: Load FactDisaster -->
        <DTS:Executable
          DTS:refId="Package\SEQ_Transform\SQL_LoadFactDisaster"
          DTS:CreationName="Microsoft.SqlServer.Dts.Tasks.ExecuteSQLTask.ExecuteSQLTask, Microsoft.SqlServer.SQLTask, Version=16.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91"
          DTS:DTSID="{3D4E5F6A-B7C8-9D0E-1F2A-B3C4D5E6F7A8}"
          DTS:ObjectName="SQL_LoadFactDisaster">
          <DTS:ObjectData>
            <SqlTaskData
              DTS:Connection="Package.ConnectionManagers[CM_DWH]"
              DTS:SqlStatementSource="EXEC dbo.usp_Load_FactDisaster;"
              DTS:ResultType="1"
              DTS:TimeOut="600" />
          </DTS:ObjectData>
        </DTS:Executable>

      </DTS:Executables>

      <!-- Execution order within SEQ_Transform -->
      <DTS:PrecedenceConstraints>
        <DTS:PrecedenceConstraint
          DTS:refId="Package\SEQ_Transform.PrecedenceConstraints[Constraint 1]"
          DTS:DTSID="{4E5F6A7B-C8D9-0E1F-2A3B-C4D5E6F7A8B9}"
          DTS:EvalOp="1"
          DTS:From="Package\SEQ_Transform\SQL_LoadDimGeography"
          DTS:To="Package\SEQ_Transform\SQL_LoadFactSeismic" />
        <DTS:PrecedenceConstraint
          DTS:refId="Package\SEQ_Transform.PrecedenceConstraints[Constraint 2]"
          DTS:DTSID="{5F6A7B8C-D9E0-1F2A-3B4C-D5E6F7A8B9C0}"
          DTS:EvalOp="1"
          DTS:From="Package\SEQ_Transform\SQL_LoadFactSeismic"
          DTS:To="Package\SEQ_Transform\SQL_LoadFactDisaster" />
      </DTS:PrecedenceConstraints>

    </DTS:Executable>

    <!-- ------------------------------------------------------------------ -->
    <!-- Step 6: Build Bridge (runs after SEQ_Transform completes)           -->
    <!-- ------------------------------------------------------------------ -->
    <DTS:Executable
      DTS:refId="Package\SQL_BuildBridge"
      DTS:CreationName="Microsoft.SqlServer.Dts.Tasks.ExecuteSQLTask.ExecuteSQLTask, Microsoft.SqlServer.SQLTask, Version=16.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91"
      DTS:DTSID="{6A7B8C9D-E0F1-2A3B-4C5D-E6F7A8B9C0D1}"
      DTS:ObjectName="SQL_BuildBridge"
      DTS:Description="Spatial-temporal matching: link FactSeismic ↔ FactDisaster via Haversine">
      <DTS:ObjectData>
        <SqlTaskData
          DTS:Connection="Package.ConnectionManagers[CM_DWH]"
          DTS:SqlStatementSource="EXEC dbo.usp_Build_BridgeDisasterSeismic @RadiusKM=100, @WindowDays=3;"
          DTS:ResultType="1"
          DTS:TimeOut="3600" />
      </DTS:ObjectData>
    </DTS:Executable>

  </DTS:Executables>

  <!-- ======================================================================
       TOP-LEVEL PRECEDENCE CONSTRAINTS
       SEQ_Extract → SEQ_Transform → SQL_BuildBridge
       ====================================================================== -->
  <DTS:PrecedenceConstraints>
    <DTS:PrecedenceConstraint
      DTS:refId="Package.PrecedenceConstraints[PC_Extract_Transform]"
      DTS:DTSID="{7B8C9D0E-F1A2-3B4C-5D6E-F7A8B9C0D1E2}"
      DTS:EvalOp="1"
      DTS:Value="0"
      DTS:From="Package\SEQ_Extract"
      DTS:To="Package\SEQ_Transform" />
    <DTS:PrecedenceConstraint
      DTS:refId="Package.PrecedenceConstraints[PC_Transform_Bridge]"
      DTS:DTSID="{8C9D0E1F-A2B3-4C5D-6E7F-A8B9C0D1E2F3}"
      DTS:EvalOp="1"
      DTS:Value="0"
      DTS:From="Package\SEQ_Transform"
      DTS:To="Package\SQL_BuildBridge" />
  </DTS:PrecedenceConstraints>

</DTS:Executable>
